# Get your free Groq API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Default model — Llama 3.3 70B is fast and high quality on Groq
GROQ_MODEL=llama-3.3-70b-versatile

# CORS — local dev: "*". Production: your Netlify URL e.g. https://agentforge.netlify.app
ALLOWED_ORIGINS=*
